@article{roachGlottalizationEnglishReexamination1973,
  title = {Glottalization of {{English}} /p/, /t/, /k/ and /T∫/—a Re-Examination},
  author = {Roach, P. J.},
  date = {1973-06},
  journaltitle = {Journal of the International Phonetic Association},
