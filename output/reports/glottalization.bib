  author = {Pierrehumbert, Janet B. and Frisch, Stefan},
  editor = {family=Santen, given=Jan P. H., prefix=van, useprefix=true and Olive, Joseph P. and Sproat, Richard W. and Hirschberg, Julia},
  date = {1997},
  pages = {9--26},
